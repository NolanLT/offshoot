{
  "name": "offshoot",
  "displayName": "Offshoot",
  "description": "Local-only PR-style review and versioning. No Git. No network. Disk is the source of truth.",
  "publisher": "LmnTrtl",
  "version": "0.4.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.84.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NolanLT/offshoot"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "review",
    "diff",
    "versioning",
    "local",
    "pr"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "bin": {
    "offshoot": "dist/mcp/server.cjs"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "offshoot",
          "title": "Offshoot",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "offshoot": [
        {
          "type": "webview",
          "id": "offshoot.sidebar",
          "name": "Offshoot"
        }
      ]
    },
    "commands": [
      {
        "command": "offshoot.openPR",
        "title": "Open New PR",
        "category": "Offshoot"
      },
      {
        "command": "offshoot.refresh",
        "title": "Refresh PR List",
        "category": "Offshoot"
      },
      {
        "command": "offshoot.commitSelection",
        "title": "Commit Selection",
        "category": "Offshoot"
      },
      {
        "command": "offshoot.revertSelection",
        "title": "Revert Selection",
        "category": "Offshoot"
      },
      {
        "command": "offshoot.toggleReview",
        "title": "Toggle Review Markers",
        "category": "Offshoot"
      },
      {
        "command": "offshoot.nextChange",
        "title": "Go to Next Change",
        "category": "Offshoot"
      },
      {
        "command": "offshoot.prevChange",
        "title": "Go to Previous Change",
        "category": "Offshoot"
      }
    ],
    "keybindings": [
      {
        "command": "offshoot.nextChange",
        "key": "alt+pagedown",
        "when": "editorTextFocus && offshoot.hasActivePR"
      },
      {
        "command": "offshoot.prevChange",
        "key": "alt+pageup",
        "when": "editorTextFocus && offshoot.hasActivePR"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "offshoot.commitSelection",
          "group": "offshoot",
          "when": "offshoot.hasActivePR"
        },
        {
          "command": "offshoot.revertSelection",
          "group": "offshoot",
          "when": "offshoot.hasActivePR"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "prepare": "node esbuild.mjs",
    "build": "npm run build:webview && npm run build:ext",
    "build:ext": "node esbuild.mjs",
    "build:webview": "vite build",
    "watch:ext": "node esbuild.mjs --watch",
    "watch:webview": "vite build --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p webview/tsconfig.json",
    "test": "esbuild test/engine.test.ts --bundle --platform=node --format=cjs --outfile=test/.out.cjs --log-level=warning && node test/.out.cjs",
    "test:mcp": "node test/mcp.test.mjs",
    "icon": "node scripts/gen-icon.mjs",
    "package": "vsce package",
    "vsix": "npx --yes @vscode/vsce package --allow-missing-repository"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^7.0.0",
    "highlight.js": "^11.11.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^20.19.43",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.84.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
